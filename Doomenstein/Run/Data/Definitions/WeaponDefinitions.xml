			<Animation name="Idle" shader="Default" spriteSheet="Data/Images/Weapons/shotgun_6x6.png" cellCount="6,6" secondsPerFrame="0.125" startFrame="34" endFrame="34" />
			<Animation name="Attack" shader="Default" spriteSheet="Data/Images/Weapons/shotgun_6x6.png" cellCount="6,6" secondsPerFrame="0.125" startFrame="2" endFrame="23" />
		</HUD>
		<Sounds>
			<Sound sound="Fire" name="Data/Audio/WeaponSounds/ShotgunShoot.ogg"/>
